# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/mjw_readme_gen

# ─── Session signing ────────────────────────────────────────────────────────
# Any long random string. Used to sign the session JWT cookie.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: openId (github:<numeric id>) of the account that should get
# role="admin" on first sign-in.
OWNER_OPEN_ID=

# ─── GitHub OAuth (login) ───────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: {your-deployed-origin}/api/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Same client ID, exposed to the browser to build the GitHub authorize link.
VITE_GITHUB_CLIENT_ID=

# ─── Anthropic (README generation) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Optional: S3 archive of uploaded zips ──────────────────────────────────
# If unset, uploaded zips are simply not archived (README generation still works).
AWS_S3_BUCKET=
AWS_REGION=us-east-1
# Standard AWS credential chain (env vars, shared config, or IAM role) is used —
# no separate access key vars needed here.
